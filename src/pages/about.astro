---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About Ben Letchford.">
  <main class="essay">
    <p class="crumb">Ben Letchford / About</p>
    <header class="essay-header">
      <p class="eyebrow">About</p>
      <h1><span aria-hidden="true">&sect;</span>Ben Letchford</h1>
    </header>
    <div class="essay-body">
      <p>
        I work on software systems, preservation tools, and small pieces of
        infrastructure that make old formats and interfaces easier to keep
        alive.
      </p>
      <p>
        This site is intentionally static. The writing lives in plain Markdown,
        the pages are built ahead of time, and the design is meant to feel
        typeset rather than assembled from product UI parts.
      </p>
      <p>
        You can reach me by <a href="mailto:ben@letchford.cloud">email</a>,
        find code on <a href="https://github.com/benletchford" rel="me noopener">GitHub</a>,
        or find work history on
        <a href="https://www.linkedin.com/in/benletchford" rel="me noopener">LinkedIn</a>.
      </p>
    </div>
  </main>
</BaseLayout>

