---
import { render } from "astro:content";
import { formatDate } from "@/lib/content";
import BaseLayout from "./BaseLayout.astro";

type Props = {
  entry: any;
};

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <main>
    <article class="essay project-page">
      <p class="crumb">Ben Letchford / Projects</p>
      <header class="essay-header">
        <p class="eyebrow">{entry.data.section}</p>
        <h1><span aria-hidden="true">&sect;</span>{entry.data.title}</h1>
        <div class="essay-meta">
          <time datetime={entry.data.date.toISOString()}>{formatDate(entry.data.date)}</time>
          {entry.data.status && <span>{entry.data.status}</span>}
        </div>
        <div class="project-actions" aria-label="Project links">
          {entry.data.url && <a href={entry.data.url} rel="noopener">Visit</a>}
          {entry.data.repository && <a href={entry.data.repository} rel="noopener">Repository</a>}
        </div>
      </header>
      <div class="essay-body">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>

