---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title?: string;
  description?: string;
};

const {
  title = "Ben Letchford",
  description = "Systems, preservation, old software, and notes from Ben Letchford.",
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <main class="home">
    <slot />
  </main>
</BaseLayout>

